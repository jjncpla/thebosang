generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  ssn       String   @unique
  phone     String?
  address   String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases     Case[]
}

model Case {
  id             String    @id @default(cuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id])

  caseType       String    @default("HEARING_LOSS")
  caseNumber     String?
  tfName         String?
  branch         String?
  subAgent       String?
  branchManager  String?
  salesManager   String?
  caseManager    String?
  salesRoute     String?
  contractDate   DateTime?
  receptionDate  DateTime?
  isOneStop      Boolean   @default(false)
  memo           String?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  hearingLoss          HearingLossDetail?
  copd                 CopdDetail?
  pneumoconiosis       PneumoconiosisDetail?
  musculoskeletal      MusculoskeletalDetail?
  occupationalAccident OccupationalAccidentDetail?
  occupationalCancer   OccupationalCancerDetail?
  bereaved             BereavedDetail?
  holidayBenefits      HolidayBenefit[]
  messages             Message[]
  timelines            TimelineEvent[]
}

model HearingLossDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status                 String  @default("접수대기")
  isDisabilityRegistered Boolean @default(false)

  firstClinic        String?
  firstExamDate      DateTime?
  firstExamRight     Float?
  firstExamLeft      Float?

  specialClinic      String?
  preExamDate        DateTime?
  exam1Date          DateTime?
  exam2Date          DateTime?
  exam3Date          DateTime?
  airRight1          Float?
  airLeft1           Float?
  boneRight1         Float?
  boneLeft1          Float?
  speechScore1       Float?
  abrRight1          Float?
  abrLeft1           Float?
  impedanceRight1    String?
  impedanceLeft1     String?

  reExamClinic       String?
  reExam1Date        DateTime?
  reExam2Date        DateTime?
  reExam3Date        DateTime?
  airRight2          Float?
  airLeft2           Float?
  boneRight2         Float?
  boneLeft2          Float?
  speechScore2       Float?
  abrRight2          Float?
  abrLeft2           Float?
  impedanceRight2    String?
  impedanceLeft2     String?

  reReExamClinic     String?
  reReExam1Date      DateTime?
  reReExam2Date      DateTime?
  reReExam3Date      DateTime?
  airRight3          Float?
  airLeft3           Float?
  boneRight3         Float?
  boneLeft3          Float?
  speechScore3       Float?
  abrRight3          Float?
  abrLeft3           Float?
  impedanceRight3    String?
  impedanceLeft3     String?

  expertOrg          String?
  expertDate         DateTime?

  disposalType       String?
  disposalDecidedAt  DateTime?
  disposalReceivedAt DateTime?
  gradeType          String?
  grade              Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id        Int      @id @default(autoincrement())
  messageId Int      @unique

  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id])

  chatId    BigInt
  userId    BigInt

  username  String?
  name      String?
  text      String?
  type      String

  fileId    String?
  filename  String?

  createdAt DateTime
  savedAt   DateTime @default(now())
}

model TimelineEvent {
  id        Int      @id @default(autoincrement())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])
  title     String
  date      DateTime
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("READONLY")
  createdAt DateTime @default(now())
}

model SignupRequest {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  department String?
  jobTitle   String?
  message    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id        String   @id @default(cuid())
  type      String
  title     String?
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CopdDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status             String    @default("접수대기")
  firstClinic        String?
  firstExamDate      DateTime?
  specialClinic      String?
  exam1Date          DateTime?
  exam2Date          DateTime?
  examResult         String?
  expertOrgDate      DateTime?
  reExamPossibleDate DateTime?
  disposalType       String?
  disposalDate       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PneumoconiosisDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status                String    @default("접수대기")
  firstClinic           String?
  firstExamDate         DateTime?
  noticeReceivedDate    DateTime?
  precisionExamDate     DateTime?
  precisionResult       String?
  precisionHospital     String?
  precisionPossibleDate DateTime?
  reExamPossibleDate    DateTime?
  disposalType          String?
  disposalDate          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MusculoskeletalDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status                 String    @default("접수대기")
  bodyPart               String?
  diseaseName            String?
  occupation             String?
  workHistory            String?
  expertType             String?
  expertRequestDate      DateTime?
  expertScheduleDate     DateTime?
  hasMedicalCommittee    Boolean   @default(false)
  committeeSubmitDate    DateTime?
  committeeReviewDate    DateTime?
  disposalType           String?
  approvalDate           DateTime?
  disabilityApprovalDate DateTime?
  hospitalName           String?
  managingBranch         String?
  treatmentStartDate     DateTime?
  treatmentEndDate       DateTime?
  claimCycle             String?
  memo                   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OccupationalAccidentDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status                 String    @default("접수대기")
  caseName               String?
  bodyPart               String?
  diseaseName            String?
  occupation             String?
  workHistory            String?
  expertType             String?
  expertRequestDate      DateTime?
  expertScheduleDate     DateTime?
  hasMedicalCommittee    Boolean   @default(false)
  committeeSubmitDate    DateTime?
  committeeReviewDate    DateTime?
  disposalType           String?
  approvalDate           DateTime?
  disabilityApprovalDate DateTime?
  hospitalName           String?
  managingBranch         String?
  treatmentStartDate     DateTime?
  treatmentEndDate       DateTime?
  claimCycle             String?
  memo                   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OccupationalCancerDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status               String    @default("접수대기")
  diseaseName          String?
  firstDiagnosisDate   DateTime?
  lastWorkplace        String?
  disposalType         String?
  disposalDate         DateTime?
  treatmentPeriod      String?
  holidayBenefitPeriod String?
  paymentStatus        String?
  memo                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BereavedDetail {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])

  status               String    @default("접수대기")
  originCaseType       String?
  diseaseName          String?
  firstDiagnosisDate   DateTime?
  lastWorkplace        String?
  disposalType         String?
  disposalDate         DateTime?
  treatmentPeriod      String?
  holidayBenefitPeriod String?
  paymentStatus        String?
  memo                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HolidayBenefit {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id])

  round     Int
  claimDate DateTime
  memo      String?

  createdAt DateTime @default(now())
}
