generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(cuid())
  name      String
  ssn       String   @unique
  phone     String?
  address   String?
  memo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases Case[]
}

model Case {
  id        String  @id @default(cuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  caseType String // HEARING_LOSS / COPD / PNEUMOCONIOSIS / MUSCULOSKELETAL / OCCUPATIONAL_ACCIDENT / OCCUPATIONAL_CANCER / BEREAVED / OTHER
  status   String @default("CONSULTING")
  // 기획사건 상태값: CONSULTING / CONTRACTED / DOC_COLLECTING / SUBMITTED /
  // EXAM_REQUESTED / EXAM_CLINIC_SELECTED / EXAM_SCHEDULED / IN_EXAM / EXAM_DONE /
  // EXPERT_REQUESTED / EXPERT_CLINIC_SELECTED / EXPERT_DONE /
  // BANK_REQUESTED / BANK_SUBMITTED / DECISION_RECEIVED /
  // REVIEWING / INFO_REQUESTED / APPROVED / REJECTED / CLOSED / OBJECTION / WAGE_CORRECTION

  // 파생 사건 연결 (평균임금 정정 청구 등)
  parentCaseId String?
  parentCase   Case?   @relation("CaseDerivation", fields: [parentCaseId], references: [id])
  derivedCases Case[]  @relation("CaseDerivation")

  // TF / 지사
  tfName String?
  branch String?

  // 담당자 (User FK)
  salesManagerId  String?
  salesManager    User?   @relation("SalesManager", fields: [salesManagerId], references: [id])
  caseManagerId   String?
  caseManager     User?   @relation("CaseManager", fields: [caseManagerId], references: [id])
  branchManagerId String?
  branchManager   User?   @relation("BranchManager", fields: [branchManagerId], references: [id])

  // 영업 정보
  salesRoute String?
  subAgent   String? // 소속/대리인
  isOneStop  Boolean @default(false)

  // 약정
  contractDate DateTime?

  // 접수
  receptionDate DateTime?

  memo String?
  closedReason String? // 반려 / 파기

  // 직업력 (상병 공통)
  workHistory      Json?   // 상용직 최종 직업력
  workHistoryDaily Json?   // 일용직 직업력
  workHistoryRaw   Json?   // 소스별 원시 직업력
  workHistoryMemo  String? // 직업력 메모
  lastNoiseWorkEndDate DateTime? // 마지막 소음작업 중단일

  // 관할 근로복지공단 지사 (서식 자동생성용)
  kwcOfficeName   String?   // 관할 공단 지사명 (예: "울산", "부산동부") → "근로복지공단 {{kwcOfficeName}}장 귀하"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 상병별 확장 테이블
  hearingLoss          HearingLossDetail?
  copd                 CopdDetail?
  pneumoconiosis       PneumoconiosisDetail?
  musculoskeletal      MusculoskeletalDetail?
  occupationalAccident OccupationalAccidentDetail?
  occupationalCancer   OccupationalCancerDetail?
  bereaved             BereavedDetail?

  objectionReviews ObjectionReview[]
  objectionCases   ObjectionCase[]

  messages  Message[]
  timelines TimelineEvent[]
  todos     Todo[]
}

model HearingLossDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  // 초진
  firstClinic            String?
  firstExamDate          DateTime?
  firstExamRight         Float?
  firstExamLeft          Float?
  firstExamSpeech        Float?
  passedInitialCriteria  Boolean   @default(false)
  isDisabilityRegistered Boolean   @default(false)
  isBig3                 Boolean   @default(false)

  disabilityRegistrationDate  DateTime? // 국가장애 등록일자
  disabilityDiagnosisDate     DateTime? // 국가장애 진단일자
  disabilityRegistrationLevel String?   // 국가장애 급수

  // 접수/청구
  claimSubmittedAt DateTime?
  claimNasPath     String?
  telegramSharedAt DateTime?

  // 특진진찰요구서
  examRequestReceivedAt DateTime?
  examPeriodStart       DateTime?
  examPeriodEnd         DateTime?

  // 특진병원 선택
  specialClinic                  String?
  examClinicSelectionSubmittedAt DateTime?

  // 특진 일정 관리
  specialExam1Date      DateTime?
  specialExam1Contact   String?
  specialExam1Attendee  String?
  specialExam2Date      DateTime?
  specialExam2Contact   String?
  specialExam2Attendee  String?
  specialExam3Date      DateTime?
  specialExam3Contact   String?
  specialExam3Attendee  String?
  specialExam4Date      DateTime?
  specialExam4Contact   String?
  specialExam4Attendee  String?
  specialExam5Date      DateTime?
  specialExam5Contact   String?
  specialExam5Attendee  String?
  reSpecialExam1Date    DateTime?
  reSpecialExam1Contact String?
  reSpecialExam1Attendee String?
  reSpecialExam2Date    DateTime?
  reSpecialExam2Contact String?
  reSpecialExam2Attendee String?
  reSpecialExam3Date    DateTime?
  reSpecialExam3Contact String?
  reSpecialExam3Attendee String?

  // 전문조사
  expertRequestReceivedAt          DateTime?
  expertClinicOptions              Json?
  expertClinic                     String?
  expertClinicSelectionSubmittedAt DateTime?
  expertDate                       DateTime?
  expertAttendedStaffId            String?
  expertMemo                       String?

  // 결정
  bankAccountRequestedAt DateTime?
  bankAccountSubmittedAt DateTime?
  decisionType           String? // APPROVED / REJECTED
  decisionReceivedAt     DateTime?
  approvedDisease        String?
  disabilityGrade        String?
  disabilityStatus       String?
  baseAssessment         String?
  finalAssessment        String?
  lumpSumAmount          Int?
  avgWage                Int?
  compensationPaidAt     DateTime?

  // 검토/정공
  wageReviewMemo             String?
  adaptedWorkplaceReviewMemo String?
  infoDisclosureRequestedAt  DateTime?
  infoDisclosureReceivedAt   DateTime?
  rejectionReason            String?
  reviewMemo                 String?

  // 장해급여청구서 — 수령계좌
  bankName              String?   // 은행(증권사)명
  bankAccount           String?   // 계좌번호
  bankAccountHolder     String?   // 예금주
  bankAccountType       String?   // "보통계좌" | "전용계좌"

  // 장해급여청구서 — 확인사항
  confirmPriorDisability   Boolean?  // ① 재해 이전 장해 여부
  confirmPriorCompensation Boolean?  // ② 동일사유 배상/보상 수령 여부
  receiptDate              String?   // 수령일자
  receiptAmount            String?   // 수령금액
  receiptPayer             String?   // 지급한 자

  // 장해급여청구서 — 이송비
  transferCost       String?   // 이송비용 (원)
  transferCostDetail String?   // 이송비 산출내역

  // 장해급여청구서 — 합병증 등 예방관리
  complicationPart     String?   // 구체적 부위 또는 상병명
  complicationHospital String?   // 합병증 등 예방관리 의료기관명

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exams HearingLossExam[]

  @@map("hearing_loss_details")
}

model HearingLossExam {
  id                  String            @id @default(cuid())
  hearingLossDetailId String
  hearingLossDetail   HearingLossDetail @relation(fields: [hearingLossDetailId], references: [id])

  examSet   String // INITIAL(최초특진) / RE(재특진) / RE2(재재특진)
  examRound Int // 1 / 2 / 3

  examDate        DateTime?
  attendedStaffId String?

  // 기도청력역치 우측 (dB) — 주파수별
  air500R   Float?
  air1kR    Float?
  air2kR    Float?
  air4kR    Float?
  // 기도청력역치 좌측 (dB)
  air500L   Float?
  air1kL    Float?
  air2kL    Float?
  air4kL    Float?
  // 골도청력역치 우측 (dB)
  bone500R  Float?
  bone1kR   Float?
  bone2kR   Float?
  bone4kR   Float?
  // 골도청력역치 좌측 (dB)
  bone500L  Float?
  bone1kL   Float?
  bone2kL   Float?
  bone4kL   Float?
  // 어음청취역치 (dB) — SRT
  srtRight  Float?
  srtLeft   Float?
  speechRight    Float?
  speechLeft     Float?
  abrRight       Float?
  abrLeft        Float?
  impedanceRight String?
  impedanceLeft  String?

  isReliable            Boolean?
  medicalRecordObtained Boolean  @default(false)
  predictedGrade        String?
  memo                  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hearing_loss_exams")
}

model CopdDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  // 초진
  firstClinic   String?
  firstExamDate DateTime?
  fev1Rate      Float?
  fev1Volume    Float?

  // 특진
  specialClinic String?
  exam1Date     DateTime?
  exam1Rate     Float?
  exam1Volume   Float?
  exam2Date     DateTime?
  exam2Rate     Float?
  exam2Volume   Float?
  examMemo      String?

  // 전문조사
  expertOrgDate      DateTime?
  reExamPossibleDate DateTime?

  // 업무상질병판정위원회
  occDiseaseCommittee String?
  occReferralDate     DateTime?
  occReviewDate       DateTime?
  occAttendanceType   String?
  occAttendanceNote   String?

  // 처분
  disposalType String?
  disposalDate DateTime?

  // 장해
  disabilityClaimDate             DateTime?
  disabilityDispositionType       String?
  disabilityGradeType             String?
  disabilityDispositionGrade      String?
  disabilityDispositionDate       DateTime?
  disabilityDispositionNoticeDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("copd_details")
}

model PneumoconiosisDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  firstClinic           String?
  firstExamDate         DateTime?
  applicableLaw         String?
  isRetired             String?
  isNoticeReceived      Boolean   @default(false)
  precisionExamDate     DateTime?
  precisionResult       String?
  precisionHospital     String?
  precisionPossibleDate DateTime?
  reExamPossibleDate    DateTime?
  disposalType          String?
  disposalDate          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pneumoconiosis_details")
}

model MusculoskeletalDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  bodyPart               String?
  diseaseName            String?
  occupation             String?
  workHistory            String?
  expertType             String?
  expertRequestDate      DateTime?
  expertScheduleDate     DateTime?
  hasMedicalCommittee    Boolean   @default(false)
  committeeSubmitDate    DateTime?
  committeeReviewDate    DateTime?
  disposalType           String?
  approvalDate           DateTime?
  disabilityApprovalDate DateTime?
  hospitalName           String?
  managingBranch         String?
  treatmentStartDate     DateTime?
  treatmentEndDate       DateTime?
  claimCycle             String?
  memo                   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("musculoskeletal_details")
}

model OccupationalAccidentDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  caseName               String?
  bodyPart               String?
  diseaseName            String?
  occupation             String?
  workHistory            String?
  expertType             String?
  expertRequestDate      DateTime?
  expertScheduleDate     DateTime?
  hasMedicalCommittee    Boolean   @default(false)
  committeeSubmitDate    DateTime?
  committeeReviewDate    DateTime?
  disposalType           String?
  approvalDate           DateTime?
  disabilityApprovalDate DateTime?
  hospitalName           String?
  managingBranch         String?
  treatmentStartDate     DateTime?
  treatmentEndDate       DateTime?
  claimCycle             String?
  memo                   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("occupational_accident_details")
}

model OccupationalCancerDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  diseaseName          String?
  firstDiagnosisDate   DateTime?
  lastWorkplace        String?
  disposalType         String?
  disposalDate         DateTime?
  treatmentPeriod      String?
  holidayBenefitPeriod String?
  paymentStatus        String?
  memo                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("occupational_cancer_details")
}

model BereavedDetail {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  originCaseType       String?
  diseaseName          String?
  firstDiagnosisDate   DateTime?
  lastWorkplace        String?
  disposalType         String?
  disposalDate         DateTime?
  treatmentPeriod      String?
  holidayBenefitPeriod String?
  paymentStatus        String?
  memo                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bereaved_details")
}

model Message {
  id        Int @id @default(autoincrement())
  messageId Int @unique

  caseId String?
  case   Case?   @relation(fields: [caseId], references: [id])

  chatId BigInt
  userId BigInt

  username String?
  name     String?
  text     String?
  type     String

  fileId   String?
  filename String?

  createdAt DateTime
  savedAt   DateTime @default(now())
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  title       String
  date        DateTime
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("READONLY")
  createdAt DateTime @default(now())

  // 노무사 전문 정보 (서식 자동생성용)
  licenseNo     String?   // 공인노무사 등록번호
  birthDate     String?   // 생년월일 "YY.MM.DD" 형식 (예: "65.03.12")
  officeAddress String?   // 사무소 주소
  officeTel     String?   // 사무실 전화
  officeFax     String?   // 팩스
  branchName    String?   // 지사/상호 (예: "울산지사")
  department    String?   // 부서
  jobTitle      String?   // 직책

  salesCases     Case[]          @relation("SalesManager")
  managedCases   Case[]          @relation("CaseManager")
  branchCases    Case[]          @relation("BranchManager")
  timelineEvents TimelineEvent[]
  consultations  Consultation[]  @relation("ConsultationManager")
  objectionCases ObjectionCase[] @relation("ObjectionManager")
  todos          Todo[]
  evaluations    StaffEvaluation[] @relation("EvaluationTarget")
  workOrders     WorkOrder[]       @relation("WorkOrderAuthor")
}

model SignupRequest {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  department String?
  jobTitle   String?
  message    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id        String   @id @default(cuid())
  type      String
  title     String?
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// 상담 관리
// ─────────────────────────────────────────────
model Consultation {
  id             String    @id @default(cuid())
  name           String
  ssn            String?
  address        String?
  phone          String
  caseTypes      String[]  // 다중 상병 (예: ["소음성난청", "근골격계"])
  managerId      String?
  manager        User?     @relation("ConsultationManager", fields: [managerId], references: [id])
  routeMain      String?   // 상담경로 대분류
  routeSub       String?   // 상담경로 중분류
  routeDetail    String?   // 상담경로 소분류
  visitDate      DateTime?
  status         String    @default("진행중") // 약정 / 종결 / 연락대기 / 진행중
  memo           String?
  progressNote   String?   // 기준 진행경과
  reminderDate   DateTime? // 알림 지정일 (없으면 3주 주기 자동)
  linkedCaseId   String?   // 약정 시 연결된 Case ID
  branchName     String?   // 담당 지사
  tfName         String?   // 담당 TF
  managerName    String?   // 담당자 이름 (텍스트, 임포트용)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([name, phone])
}

// ─────────────────────────────────────────────
// TF 텔레그램 메시지 (webhook 저장)
// ─────────────────────────────────────────────
model TelegramMessage {
  id          String   @id @default(cuid())
  tfName      String   // 담당 TF명
  messageId   String?  // 텔레그램 메시지 ID (중복 방지)
  senderName  String?
  content     String?  @db.Text
  mediaType   String?  // photo / document / video / none
  mediaUrl    String?  // 저장된 미디어 경로 (NAS 또는 로컬)
  sentAt      DateTime
  isProcessed Boolean  @default(false) // 재해자 DB 반영 여부
  linkedCaseId String? // 연결된 Case ID
  createdAt   DateTime @default(now())

  @@unique([tfName, messageId])
}

// ─────────────────────────────────────────────
// 이의제기 최초총현황 (결정 수신 후 검토)
// ─────────────────────────────────────────────
model ObjectionReview {
  id             String    @id @default(cuid())
  caseId         String?
  case           Case?     @relation(fields: [caseId], references: [id])
  tfName         String
  patientName    String
  caseType       String    // 소음성 난청 / COPD 등
  decisionDate   DateTime? // 처분일 (제척기간 기산일)
  approvalStatus String    // 승인 / 불승인 / 일부승인
  progressStatus String    // 종결 / 검토중 / 이의제기 진행 / 송무 검토 / 송무 인계 / 평정 청구 진행
  hasInfoDisclosure Boolean @default(false) // 정공 여부
  memo           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  objectionCases ObjectionCase[]
}

// ─────────────────────────────────────────────
// 이의제기 기일 관리 (심사/재심사 청구 및 결과)
// ─────────────────────────────────────────────
model ObjectionCase {
  id                    String    @id @default(cuid())
  reviewId              String?   // ObjectionReview FK (최초총현황과 연결)
  review                ObjectionReview? @relation(fields: [reviewId], references: [id])
  caseId                String?
  case                  Case?     @relation(fields: [caseId], references: [id])
  tfName                String    // TF명 (예: 울산동부TF)
  patientName           String
  caseType              String    // 소음성 난청 / COPD / 근골격계 등
  approvalStatus        String    // 승인 / 불승인 / 일부승인
  decisionDate          DateTime? // 처분일(안날) — 제척기간 기산일
  // 심사청구
  examClaimDate         DateTime? // 심사청구일
  examResult            String?   // 기각 / 인용 / 취하 / null(진행중)
  examResultDate        DateTime? // 심사 결정 송달일
  // 재심사청구
  reExamClaimDate       DateTime? // 재심사청구일
  reExamResult          String?   // 기각 / 인용 / 취하 / null(진행중)
  reExamResultDate      DateTime? // 재심사 결정 송달일
  // 업무상질병판정위원회 해당 여부 (질판위 거친 경우 심사 건너뛰고 재심사부터 가능)
  isQualityReview       Boolean   @default(false)
  // 담당자
  managerId             String?
  manager               User?     @relation("ObjectionManager", fields: [managerId], references: [id])
  // 진행 상태
  progressStatus        String    // 진행중 / 종결 / 송무인계 / 검토중
  memo                  String?
  reasonContent         String?   // 이유서·의견서 본문 내용
  // 소송 인계 관련
  litigationHandover    Boolean   @default(false) // 송무 인계 여부
  litigationMemo        String?
  // 재처분 필요 여부 (제척 도과 시 자동 계산)
  needsReDecision       Boolean   @default(false)
  // 소송 상태
  litigationStatus      String?   // 소송 검토중 / 소송 검토 완료 / 소송 진행중 / 소송 종료
  wageCorrectStatus     String?   // 접수 대기 / 진행중 / 처분완료
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ─────────────────────────────────────────────
// 평균임금 데이터 검토 (정보공개청구 후 입력)
// ─────────────────────────────────────────────
model WageReviewData {
  id                    String    @id @default(cuid())
  caseId                String?   // Case FK
  tfName                String
  patientName           String
  caseType              String
  decisionDate          DateTime?
  hasInfoDisclosure     Boolean   @default(false) // 정공 여부
  retirementDate        DateTime? // 퇴직일자
  diagnosisDate         DateTime? // 산정사유발생일(진단일)
  hasNationalDisability Boolean   @default(false) // 국가장애여부
  disabilityGrade       String?   // 급수
  workerType            String?   // 일용 / 상용
  // 임금 산정 결과
  comparisonWage        String?   // 비교임금 (실임금/동종임금/특례 등)
  appliedWage           String?   // 적용임금 유형
  workplaceName         String?   // 적용사업장명
  occupation1           String?   // 직종1
  occupation1Years      String?   // 직종1 직력
  occupation2           String?   // 직종2
  occupation2Years      String?
  occupation3           String?   // 직종3
  occupation3Years      String?
  // 실제임금
  baseAvgWage           Float?    // 최초산출평균임금
  basisNote             String?   // 산정 근거
  hasCommuteCoef        Boolean?  // 통상근로계수 적용여부
  changeRate            Float?    // 증감률
  finalAvgWage          Float?    // 적용평균임금
  // 동종근로자/임금구조 임금
  statWageGender        String?   // 성별
  statWageSize          String?   // 규모
  statWageIndustry      String?   // 업종
  statWageOccupation    String?   // 직종
  statWageQuarter       String?   // 적용분기
  statWageBase          Float?    // 최초산정임금
  statWageChangeRate    Float?    // 증감률
  statWageFinal         Float?    // 적용평균임금
  // 최종 산정
  finalSelectedWage     Float?    // 최종 채택 평균임금
  // 검토 결과
  reviewManagerName     String?   // 검토 담당자 (자유텍스트)
  reviewResult          String?   // 종결 / 평정진행 등
  reviewDetail          String?   // 상세 쟁점
  progressNote          String?   // 진행경과
  claimDate             DateTime? // 평정/적사변 청구일
  decisionResultDate    DateTime? // 결정일
  additionalReview      String?   // 추가 검토
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Todo {
  id          String    @id @default(cuid())
  title       String
  dueDate     DateTime?
  type        String    // OBJECTION_DEADLINE / WAGE_REQUEST / GENERAL
  caseId      String?
  patientName String?
  assignedTo  String?
  isDone      Boolean   @default(false)
  memo        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  case        Case?     @relation(fields: [caseId], references: [id])
  user        User?     @relation(fields: [assignedTo], references: [id])
}

// ─────────────────────────────────────────────
// 운영규정·취업규칙 문서
// ─────────────────────────────────────────────
model PolicyDocument {
  id          String   @id @default(cuid())
  title       String
  category    String                        // OPERATION_RULE | WORK_RULE | OTHER
  version     String?
  fileUrl     String?
  content     String?  @db.Text
  isLatest    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// 인사평가
// ─────────────────────────────────────────────
model StaffEvaluation {
  id               String   @id @default(cuid())
  userId           String
  evaluatorId      String?
  period           String
  score            Int?
  performanceScore Int?
  attendanceScore  Int?
  attitudeScore    Int?
  isPromotionTarget Boolean @default(false)
  promotionGrade   String?
  memo             String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User @relation("EvaluationTarget", fields: [userId], references: [id])
}

// ─────────────────────────────────────────────
// 업무 지시 게시판
// ─────────────────────────────────────────────
model WorkOrder {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  authorId    String
  dueDate     DateTime?
  priority    String    @default("NORMAL")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author    User @relation("WorkOrderAuthor", fields: [authorId], references: [id])
}
