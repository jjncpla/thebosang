{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma generate --schema=prisma/auth.prisma && next build",
    "start": "next start",
    "lint": "eslint",
    "db:auth:generate": "prisma generate --schema=prisma/auth.prisma",
    "db:auth:push": "prisma db push --schema=prisma/auth.prisma",
    "db:auth:migrate": "prisma migrate dev --schema=prisma/auth.prisma",
    "db:auth:seed": "node scripts/seed-auth.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "handlebars": "^4.7.8",
    "lodash.get": "^4.4.2",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^5.22.0",
    "puppeteer-core": "^24.38.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/handlebars": "^4.0.40",
    "@types/lodash.get": "^4.4.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
