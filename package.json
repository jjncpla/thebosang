{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma generate --schema=prisma/auth.prisma && prisma db push --skip-generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "db:auth:generate": "prisma generate --schema=prisma/auth.prisma",
    "db:auth:push": "prisma db push --schema=prisma/auth.prisma",
    "db:auth:migrate": "prisma migrate dev --schema=prisma/auth.prisma",
    "db:auth:seed": "node scripts/seed-auth.mjs"
  },
  "dependencies": {
    "@google-cloud/documentai": "^9.6.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.22.0",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^3.0.3",
    "handlebars": "^4.7.8",
    "lodash.get": "^4.4.2",
    "next": "~15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^5.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/handlebars": "^4.0.40",
    "@types/lodash.get": "^4.4.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "~15.5.14",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
