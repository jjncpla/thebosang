generator auth_client {
  provider = "prisma-client-js"
  output   = "../lib/generated/auth-client"
}

datasource db_auth {
  provider = "postgresql"
  url      = env("DATABASE_AUTH_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("READONLY")
  createdAt DateTime @default(now())
}

model SignupRequest {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  department String?
  jobTitle   String?
  message    String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Notice {
  id        String   @id @default(cuid())
  type      String
  title     String?
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
